[2026-06-05 16:23:41] verify_arxiv() {
  for id in "$@"; do
    title=$(curl -sL "https://export.arxiv.org/api/query?id_list=$id" | grep -A1 "<entry>" | grep "<title>" | sed 's/<[^>]*>//g' | tr -s ' ')
    # fallback parse
    if [ -z "$title" ]; then
      title=$(curl -sL "https://export.arxiv.org/api/query?id_list=$id" | python3 -c "import sys,re; t=sys.stdin.read(); m=re.findall(r'<title>(.*?)</title>',t,re.S); print(m[1].strip() if len(m)>1 else 'NOTFOUND')")
    fi
    echo "$id :: $title"
  done
}
